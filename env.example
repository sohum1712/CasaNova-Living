# Main environment file to be replicated across each sub component of app

# Postgres — use either discrete vars OR DATABASE_URL (not both required)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_SCHEMA=public
DB_USER=your_username
DB_PASSWORD=your_password
# DATABASE_URL=postgresql://user:password@localhost:5432/postgres
# DB_SSLMODE=require

# JWT signing key (required in production)
JWT_SECRET_KEY=
# ALLOW_INSECURE_JWT_DEFAULT=1   # local dev only — never enable in production

# FastAPI
DEBUG=True
API_PREFIX=/api
# CORS_ORIGINS=https://app.example.com,http://localhost:5173

# Python Logging Configuration
LOG_LEVEL=INFO

# Databricks Configuration (for local development)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_personal_access_token

# Frontend (Vite) — dev usually uses /api proxy; set full URL only if needed
VITE_APP_NAME="CasaNova Living"
VITE_APP_VERSION=1.0.0
# VITE_API_BASE_URL=/api